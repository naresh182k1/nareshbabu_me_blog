---
// Chatbot Widget - Placeholder for third-party chatbot integration
// Replace the contents of this component with your preferred chatbot provider
// (e.g., Intercom, Drift, Tidio, Crisp, or a custom AI chatbot)
---

<div id="chatbot-widget" class="fixed bottom-6 right-6 z-50">
  <!-- Chat Toggle Button -->
  <button
    id="chatbot-toggle"
    class="w-14 h-14 rounded-full bg-primary text-white shadow-lg hover:bg-primary-light transition-all hover:scale-105 flex items-center justify-center"
    aria-label="Open chat"
  >
    <svg id="chat-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
    </svg>
    <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>

  <!-- Chat Window -->
  <div id="chatbot-window" class="hidden absolute bottom-20 right-0 w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-border overflow-hidden">
    <div class="bg-primary text-white p-4">
      <h3 class="font-semibold">Chat with us</h3>
      <p class="text-sm text-white/70">We typically reply within a few hours</p>
    </div>
    <div class="p-6 h-64 flex items-center justify-center text-center">
      <div>
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-surface flex items-center justify-center">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
        </div>
        <p class="text-text-light text-sm">Chatbot integration coming soon.</p>
        <p class="text-text-light text-xs mt-1">In the meantime, <a href="/contact" class="text-primary underline">contact us here</a>.</p>
      </div>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('chatbot-toggle');
  const window_ = document.getElementById('chatbot-window');
  const chatIcon = document.getElementById('chat-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = window_?.classList.toggle('hidden') === false;
    chatIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-label', isOpen ? 'Close chat' : 'Open chat');
  });
</script>
